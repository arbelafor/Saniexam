<?xml version="1.0" encoding="utf-8"?>
<!--
   Block both cloud backup and device-to-device transfer. Progress lives in
   Room; users can export/import manually via the in-app backup flow (PR4).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
